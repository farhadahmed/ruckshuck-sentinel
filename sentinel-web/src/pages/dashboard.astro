---
import BaseLayout from '../layouts/BaseLayout.astro';

// Check auth: if no session, redirect to login
const sessionCookie = Astro.cookies.get('sentinel_session')?.value;
if (!sessionCookie) {
  return Astro.redirect('/login');
}

// Fetch user info from /api/me
let user: any = null;
let apiError: string | null = null;

try {
  const response = await fetch('http://localhost:4321/api/me', {
    headers: { Cookie: `sentinel_session=${sessionCookie}` },
  });
  if (response.ok) {
    const data = await response.json();
    user = data.user;
  } else {
    apiError = 'Session invalid or expired';
  }
} catch (err) {
  apiError = 'Failed to fetch user info';
}

// If auth failed, redirect to login
if (!user || apiError) {
  return Astro.redirect('/login');
}
---

<BaseLayout title="Dashboard - Sentinel Web">
  <div class="min-h-screen bg-gray-50">
    <!-- Header -->
    <header class="bg-white shadow">
      <div class="max-w-6xl mx-auto px-4 py-4 sm:px-6 lg:px-8 flex justify-between items-center">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
          <p class="text-gray-600 text-sm mt-1">Welcome, {user.email}</p>
        </div>
        <button
          id="logoutBtn"
          class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition"
        >
          Logout
        </button>
      </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-6xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Access Context</h2>
          <p class="text-gray-600 text-sm mb-4">
            Search Google Workspace login events and enriched access context data.
          </p>
          <button
            id="fetchDataBtn"
            class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition"
          >
            Fetch Sample Data
          </button>
        </div>

        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Platform Configuration</h2>
          <p class="text-gray-600 text-sm mb-4">
            Configure your security data sources and integrations.
          </p>
          <button
            disabled
            class="px-4 py-2 bg-gray-400 text-white rounded-lg cursor-not-allowed"
          >
            Coming Soon
          </button>
        </div>
      </div>

      <!-- Data Display Area -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Data</h2>
        <div id="dataContainer" class="text-gray-600 text-sm">
          Click "Fetch Sample Data" to load data from sentinel-access-context-api.
        </div>
      </div>
    </main>
  </div>

  <script>
    const logoutBtn = document.getElementById('logoutBtn') as HTMLButtonElement | null;
    const fetchDataBtn = document.getElementById('fetchDataBtn') as HTMLButtonElement | null;
    const dataContainer = document.getElementById('dataContainer') as HTMLDivElement | null;

    logoutBtn?.addEventListener('click', async () => {
      try {
        await fetch('/api/logout', {
          method: 'POST',
          credentials: 'include',
        });
        window.location.href = '/';
      } catch (err) {
        console.error('Logout error:', err);
      }
    });

    fetchDataBtn?.addEventListener('click', async () => {
      if (!fetchDataBtn || !dataContainer) return;
      
      fetchDataBtn.disabled = true;
      dataContainer.innerHTML = '<p class="text-gray-500">Loading...</p>';

      try {
        // Call sentinel-access-context-api on localhost:8000
        const response = await fetch('http://localhost:8000/api/sample-data');
        if (!response.ok) {
          throw new Error('Failed to fetch data from API');
        }
        const data = await response.json();
        dataContainer.innerHTML = `<pre class="bg-gray-100 p-4 rounded overflow-auto text-xs">${JSON.stringify(data, null, 2)}</pre>`;
      } catch (err) {
        const message = err instanceof Error ? err.message : 'An error occurred';
        dataContainer.innerHTML = `<p class="text-red-600">${message}</p>`;
      } finally {
        fetchDataBtn.disabled = false;
      }
    });
  </script>
</BaseLayout>
