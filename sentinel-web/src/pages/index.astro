---
import BaseLayout from '../layouts/BaseLayout.astro';

// Redirect to dashboard if already logged in
const sessionCookie = Astro.cookies.get('sentinel_session')?.value;
if (sessionCookie) {
  return Astro.redirect('/dashboard');
}
---

<BaseLayout title="Sentinel Web - Home">
  <div class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100 flex items-center justify-center px-4">
    <div class="text-center max-w-2xl">
      <h1 class="text-5xl font-bold text-gray-900 mb-4">Sentinel Web</h1>
      <p class="text-xl text-gray-700 mb-8">
        AI-assisted Security Operations Center for secure data investigation and analysis.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/login"
          class="px-8 py-3 bg-indigo-600 text-white rounded-lg font-semibold hover:bg-indigo-700 transition"
        >
          Login
        </a>
        <a
          href="/signup"
          class="px-8 py-3 bg-white text-indigo-600 border-2 border-indigo-600 rounded-lg font-semibold hover:bg-indigo-50 transition"
        >
          Sign Up
        </a>
      </div>

      <p class="text-gray-600 mt-8 text-sm">
        Learn more about Sentinel at <a
          href="https://github.com/ruckshuck"
          class="text-indigo-600 hover:underline"
        >
          github.com/ruckshuck
        </a>
      </p>
    </div>
  </div>
</BaseLayout>
