---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Sentinel Web' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Sentinel Web - AI-assisted Security Operations Center"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
